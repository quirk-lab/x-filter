{
  "name": "x-filter-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @x-filter/playground dev",
    "storybook": "pnpm --filter @x-filter/storybook dev",
    "storybook:build": "pnpm --filter @x-filter/storybook build",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm exec jest --runInBand",
    "security": "pnpm audit",
    "prepare": "husky install",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "antd": "^5.0.0",
    "husky": "^9.1.5",
    "jest": "^29.7.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.4.0",
    "madge": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vite": "^6.4.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once@2.0.0": "2.0.1",
      "brace-expansion@1.1.12": "1.1.15",
      "diff@4.0.2": "4.0.4",
      "esbuild@0.21.5": "0.25.12",
      "glob@10.4.5": "10.5.0",
      "handlebars@4.7.8": "4.7.9",
      "minimatch@3.1.2": "3.1.5",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "postcss": "8.5.15",
      "postcss@8.5.6": "8.5.15",
      "rollup@4.54.0": "4.60.4",
      "uuid@9.0.1": "11.1.1",
      "ws@8.18.3": "8.21.0",
      "yaml@2.8.2": "2.9.0"
    }
  }
}
