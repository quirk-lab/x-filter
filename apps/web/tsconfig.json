{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "module": "ESNext",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@x-filter/antd": ["../../packages/antd/src"],
      "@x-filter/core": ["../../packages/core/src"],
      "@x-filter/core/*": ["../../packages/core/src/*"],
      "@x-filter/react": ["../../packages/react/src"],
      "@x-filter/shadcn": ["../../packages/shadcn/src"]
    },
    "plugins": [{ "name": "next" }],
    "types": ["node", "jest"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "**/*.md", "**/*.mdx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "dist", "out"]
}
