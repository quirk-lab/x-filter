{
  "name": "@x-filter/react",
  "version": "0.1.0",
  "description": "Headless React hooks for the X-Filter query builder — state management, view models, DSL editor, URL sync, presets, undo/redo, and keyboard navigation.",
  "license": "MIT",
  "author": "thomaszdxsn <bnm965321@gmail.com> (https://github.com/quirk-lab)",
  "homepage": "https://x-filter.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quirk-lab/x-filter.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/quirk-lab/x-filter/issues"
  },
  "keywords": [
    "filter",
    "query-builder",
    "filter-builder",
    "react",
    "headless",
    "hooks",
    "dsl",
    "query",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src",
    "format": "biome format src --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@x-filter/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
