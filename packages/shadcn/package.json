{
  "name": "@x-filter/shadcn",
  "version": "0.2.0",
  "description": "shadcn/Tailwind UI adapter for the X-Filter query builder — composable atomic components with DnD, DSL editor, and ARIA tree keyboard navigation.",
  "license": "MIT",
  "author": "thomaszdxsn <bnm965321@gmail.com> (https://github.com/quirk-lab)",
  "homepage": "https://x-filter.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quirk-lab/x-filter.git",
    "directory": "packages/shadcn"
  },
  "bugs": {
    "url": "https://github.com/quirk-lab/x-filter/issues"
  },
  "keywords": [
    "filter",
    "query-builder",
    "filter-builder",
    "react",
    "shadcn",
    "tailwind",
    "headless",
    "dsl",
    "query",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src",
    "format": "biome format src --write",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@x-filter/core": "workspace:*",
    "@x-filter/react": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.0.0",
    "@radix-ui/react-checkbox": "^1.0.0",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-label": "^2.0.0",
    "@radix-ui/react-popover": "^1.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tooltip": "^1.0.0",
    "lucide-react": "^0.300.0",
    "react": "^18.3.1 || ^19",
    "react-dom": "^18.3.1 || ^19",
    "tailwindcss": "^3.0.0 || ^4.0.0"
  }
}
