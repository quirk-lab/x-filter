{
  "name": "@x-filter/core",
  "version": "0.1.0",
  "description": "Schema-driven filter query builder core — tree model, mutations, validation, DSL, and query exporters (SQL, JsonLogic, MongoDB, Elasticsearch).",
  "license": "MIT",
  "author": "thomaszdxsn <bnm965321@gmail.com> (https://github.com/quirk-lab)",
  "homepage": "https://x-filter.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quirk-lab/x-filter.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/quirk-lab/x-filter/issues"
  },
  "keywords": [
    "filter",
    "query-builder",
    "filter-builder",
    "dsl",
    "sql",
    "mongodb",
    "elasticsearch",
    "jsonlogic",
    "query",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./sql": {
      "import": {
        "types": "./dist/sql/index.d.ts",
        "default": "./dist/sql/index.js"
      },
      "require": {
        "types": "./dist/sql/index.d.cts",
        "default": "./dist/sql/index.cjs"
      }
    },
    "./dsl": {
      "import": {
        "types": "./dist/dsl/index.d.ts",
        "default": "./dist/dsl/index.js"
      },
      "require": {
        "types": "./dist/dsl/index.d.cts",
        "default": "./dist/dsl/index.cjs"
      }
    },
    "./jsonlogic": {
      "import": {
        "types": "./dist/jsonlogic/index.d.ts",
        "default": "./dist/jsonlogic/index.js"
      },
      "require": {
        "types": "./dist/jsonlogic/index.d.cts",
        "default": "./dist/jsonlogic/index.cjs"
      }
    },
    "./mongodb": {
      "import": {
        "types": "./dist/mongodb/index.d.ts",
        "default": "./dist/mongodb/index.js"
      },
      "require": {
        "types": "./dist/mongodb/index.d.cts",
        "default": "./dist/mongodb/index.cjs"
      }
    },
    "./elasticsearch": {
      "import": {
        "types": "./dist/elasticsearch/index.d.ts",
        "default": "./dist/elasticsearch/index.js"
      },
      "require": {
        "types": "./dist/elasticsearch/index.d.cts",
        "default": "./dist/elasticsearch/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src",
    "format": "biome format src --write",
    "typecheck": "tsc --noEmit"
  }
}
