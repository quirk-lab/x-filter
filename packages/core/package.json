{
  "name": "@x-filter/core",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./sql": {
      "import": {
        "types": "./dist/sql/index.d.ts",
        "default": "./dist/sql/index.js"
      },
      "require": {
        "types": "./dist/sql/index.d.cts",
        "default": "./dist/sql/index.cjs"
      }
    },
    "./dsl": {
      "import": {
        "types": "./dist/dsl/index.d.ts",
        "default": "./dist/dsl/index.js"
      },
      "require": {
        "types": "./dist/dsl/index.d.cts",
        "default": "./dist/dsl/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint src",
    "format": "biome format src --write",
    "typecheck": "tsc --noEmit"
  }
}
